# Kopiér denne fil til ".env" og udfyld værdierne.
# Disse er KUN server-side (læses af /api funktionerne) og bliver aldrig sendt til browseren.

# --- Supabase ---------------------------------------------------------
# Project Settings → API
SUPABASE_URL=https://dit-projekt.supabase.co
SUPABASE_SERVICE_ROLE_KEY=ey...  # "service_role" nøglen (hemmelig!)
# Postgres-forbindelse til migrationer (scripts/migrate.mjs, npm run migrate).
# IPv4 session-pooler, Project Settings → Database → Connection string (Session).
SUPABASE_DB_URL=postgresql://postgres.dit-projekt:DIT-DB-PASSWORD@aws-1-eu-central-1.pooler.supabase.com:5432/postgres

# --- GatewayAPI (https://gatewayapi.com) ------------------------------
# API-token oprettes under "API-nøgler".
GATEWAYAPI_TOKEN=din-gatewayapi-token
# Afsendernavn vist på SMS'en (max 11 tegn, bogstaver). Kan også styres i Indstillinger.
GATEWAYAPI_SENDER=Restaurant

# --- Landekode --------------------------------------------------------
# Bruges når et 8-cifret nummer indtastes uden landekode (45 = Danmark).
DEFAULT_COUNTRY_CODE=45
